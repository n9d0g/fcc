{
	"name": "fcc",
	"private": true,
	"author": "Nathan Lardizabal <nate@njil.dev>",
	"maintainers": [
		"Nathan Lardizabal <nate@njil.dev>"
	],
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "oxfmt",
		"clean": "rm -rf node_modules pnpm-lock.yaml apps/*/node_modules apps/*/.svelte-kit apps/*/.turbo",
		"fresh": "pnpm format && pnpm clean && pnpm install",
		"fresh:start": "pnpm fresh && pnpm dev",
		"cms:deploy": "cd apps/cms && sanity deploy",
		"changeset": "pnpm changeset && pnpm changeset status --verbose && pnpm changeset version"
	},
	"dependencies": {
		"@sveltejs/kit": "^2.15.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0",
		"vite": "^6.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.27.1",
		"eslint": "^8.48.0",
		"oxfmt": "^0.35.0",
		"tsconfig": "*",
		"turbo": "latest"
	},
	"packageManager": "pnpm@10.30.3",
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild"]
	}
}
