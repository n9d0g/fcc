{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "es5",
	"printWidth": 80,
	"semi": false,
	"ignorePatterns": [
		".DS_Store",
		".svelte-kit",
		"node_modules",
		"/build",
		"/package",
		".env",
		".env.*",
		"!.env.example",
		"vite.config.js*",
		"pnpm-lock.yaml",
		"pnpm-workspace.yaml",
		"package-lock.json",
		"yarn.lock",
	],
}
